APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# AT-173 — application-level media encryption at rest (WhatsApp media, FICA docs).
# Generate per-environment with `php artisan media:key:generate`. NEVER commit a real
# value. Separate from APP_KEY on purpose. Losing it makes encrypted media unrecoverable.
MEDIA_ENCRYPTION_KEY=
# MEDIA_ENCRYPTION_KEY_PREVIOUS=   # set only during a key rotation window
# MEDIA_ENCRYPTION_ENABLED=true    # defaults to true when a key is present

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# Dedicated DB for demo seeding / seeder-verification (the 'demo'
# connection). NEVER point this at the real DB. See .ai/DEMO_SEEDING.md.
# DB_DEMO_DATABASE=nexus_os_demo

# Allows demo:seed / demo:cleanup to be hand-run on a non-local environment.
# DEMO_SEED_ALLOWED=true

# Allows the UNATTENDED demo:refresh job (drops the demo DB and rebuilds it
# every DEMO_REFRESH_INTERVAL_DAYS at 03:00 SAST). Deliberately SEPARATE from
# DEMO_SEED_ALLOWED: authorising an operator to hand-run a seed is not the same
# decision as authorising a 3am job to drop a database. Set ONLY on the demo
# box — live and staging run the same scheduler off the same routes/console.php,
# and the default of false is what keeps them safe.
# DEMO_REFRESH_ENABLED=true
# DEMO_REFRESH_INTERVAL_DAYS=3
# The EXACT database this box is permitted to DESTROY. demo:refresh refuses
# unless the 'demo' connection resolves to precisely this name — so a mistyped
# or inherited DB_DEMO_DATABASE cannot silently redirect the wipe elsewhere.
# There is no default: "which database may I destroy" is never answered by
# convention.
# DEMO_REFRESH_DATABASE=nexus_os_demo

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Dedicated CoreX notification mailer (agent testimonial alerts etc.). Sends via
# real SMTP from mail@corexos.co.za so it delivers even when MAIL_MAILER=log
# (staging). Set the real password in .env only — never commit it.
MAIL_COREX_HOST=mail.corexos.co.za
MAIL_COREX_PORT=587
MAIL_COREX_ENCRYPTION=tls
MAIL_COREX_USERNAME=mail@corexos.co.za
MAIL_COREX_PASSWORD=null
MAIL_COREX_FROM_ADDRESS=mail@corexos.co.za
MAIL_COREX_FROM_NAME="CoreX OS"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# PDF Splitter tool paths (defaults use system PATH)
# On Windows, set full paths e.g. "C:/Program Files/qpdf 12.2.0/bin/qpdf.exe"
# On Linux, leave as default or set e.g. "/usr/bin/qpdf"
SPLITTER_QPDF_PATH=qpdf
SPLITTER_PDFTOPPM_PATH=pdftoppm
SPLITTER_PDFUNITE_PATH=pdfunite
SPLITTER_TESSERACT_PATH=tesseract

# Property24 Alert Email Import (IMAP)
P24_IMAP_HOST=mail.hfcoastal.co.za
P24_IMAP_PORT=993
P24_IMAP_ENCRYPTION=ssl
P24_IMAP_USERNAME=sales@hfcoastal.co.za
P24_IMAP_PASSWORD=
P24_IMAP_FOLDER=INBOX
P24_IMPORT_ENABLED=true

# Puppeteer browser path for PDF generation (html-to-pdf.mjs)
# On Linux: /usr/bin/chromium-browser or /usr/bin/chromium
# On Windows: leave blank (auto-detects Microsoft Edge)
PUPPETEER_BROWSER_PATH=

# Private Property Portal Syndication
PP_USERNAME=
PP_PASSWORD=
PP_BRANCH_GUID=
PP_WSDL=https://services.sandbox.pp.co.za/AgentImport/AgentImport.asmx?WSDL
PP_SANDBOX=true
# Override APP_URL for image hosts (use when developing locally against PP
# sandbox: set to the public HTTPS host that serves /storage/*).
PP_IMAGE_BASE_URL=
# HMAC SHA256 shared secret for the inbound PP webhook (set per webhook in
# the PP Admin Portal). Without this, /pp/webhook returns 500.
# (Defined below under "PDF_NODE_WRAPPER" historically — re-listed here for discoverability.)

# Property24 ExDev Syndication (Outbound)
P24_EXDEV_API_URL=https://api.exdev.property24-test.com
P24_EXDEV_USERNAME=
P24_EXDEV_PASSWORD=
P24_EXDEV_AGENCY_ID=
P24_EXDEV_SANDBOX=true
P24_EXDEV_IMAGE_BASE_URL=https://corex.hfcoastal.co.za

# Meta (Facebook/Instagram) Marketing Integration
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/corex/social/oauth/callback

# Wrapper script for PDF generation on server (runs via sudo)
# Set to the full path of the wrapper, e.g. /usr/local/bin/generate-pdf.sh
# Leave blank for local dev (uses node directly)
PDF_NODE_WRAPPER=
PP_WEBHOOK_SECRET=

# Firebase Cloud Messaging (FCM v1) — used by App\Services\Push\FcmService
# FIREBASE_CREDENTIALS must point to the service account JSON file (absolute path).
FIREBASE_PROJECT=app
FIREBASE_CREDENTIALS=

# Whistleblower compliance reporting
# When PPRA_LIVE_SEND=false: emails route to DEMO_RECIPIENT
# with [DEMO] subject prefix. Production emails to PPRA only
# when set to true (post-lawyer-review).
WHISTLEBLOW_PPRA_LIVE_SEND=false
WHISTLEBLOW_DEMO_RECIPIENT=johan@hfcoastal.co.za

# ─────────────────────────────────────────────────────────────────────
# Anthropic API (Market Intelligence Centre + Docuperfect AI features)
# ─────────────────────────────────────────────────────────────────────
# Get your API key from https://console.anthropic.com/settings/keys.
# The key is read by `App\Services\AI\AnthropicGateway` and the legacy
# Docuperfect AI services. Leave ANTHROPIC_ENABLED=false to force every
# call to use its deterministic fallback (useful for local dev without
# an API key, and for cost-control kill-switches in prod).
ANTHROPIC_API_KEY=
ANTHROPIC_ENABLED=true
ANTHROPIC_FAST_MODEL=claude-haiku-4-5
ANTHROPIC_QUALITY_MODEL=claude-sonnet-4-6
# Quarterly: refresh from a fresh USD→ZAR midmarket rate.
ANTHROPIC_USD_TO_ZAR=16.50  # current as of May 2026, update quarterly


# ─────────────────────────────────────────────────────────────────────
# Public listing website (custom CoreX website)
# ─────────────────────────────────────────────────────────────────────
# Base URL of the public website where individual listings render. Feeds
# Property::getPublicUrlAttribute() → {PUBLIC_WEBSITE_URL}/property/{slug}-{id}
# (the "View on website" button on the Properties page). Defaults to the live
# production domain; override to point at a local/staging custom-website server.
PUBLIC_WEBSITE_URL=https://www.hfcoastal.co.za


# ─────────────────────────────────────────────────────────────────────
# Demo Access Control (AT-230) — .ai/specs/demo-access-control.md
# ─────────────────────────────────────────────────────────────────────
# Which half of the codebase is live on this host: primary | demo.
#   primary — the real install (live/staging/local). Issues grants, owns the
#             durable records, mints the demo connector. Gate/watermark/countdown
#             are all inert.
#   demo    — demo1.corexos.co.za. Gated, watermarked, reset every 3 days.
# Anything other than the exact string "demo" is treated as primary, so a typo can
# never turn a real install into a wipeable one.
#
# THIS IS THE ONLY DEMO KEY YOU NEED TO SET. The demo's connection to CoreX (the
# address + the connector token) is configured IN THE BROWSER: sign in to the demo
# as a System Owner and go to Dev Settings → Demo Connection. No deploy, no SSH —
# and a signed-in owner bypasses the demo gate, so a bad token can never lock you
# out of fixing it.
COREX_INSTANCE_ROLE=primary

# Optional bootstrap fallback for the demo→CoreX connection. The Demo Connection
# page is the normal path and takes precedence over these. They exist only so a
# demo host CAN be pre-wired from a .env if you prefer. Leave blank on primary.
COREX_DEMO_CONTROL_URL=
COREX_DEMO_CONTROL_TOKEN=
