<?php

namespace App\Http\Controllers\Admin;

use App\Http\Controllers\Controller;
use App\Services\Admin\CompanyPerformanceService;
use App\Services\Finance\CommissionCalculator;
use App\Services\Finance\FinanceReadModel;
use Carbon\Carbon;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;

class AgentPerformanceController extends Controller
{
    public function show(Request $request, int $userId, CompanyPerformanceService $service)
    {
        $period = $request->query('period') ?: Carbon::now()->format('Y-m');
        $start = Carbon::createFromFormat('Y-m', $period)->startOfMonth();
        $end   = (clone $start)->endOfMonth();

        // Base agent identity
        $agent = DB::table('users')->where('id', $userId)->select('id','name','email','role','branch_id')->first();
        abort_unless($agent && strtolower(trim((string)($agent->role ?? ''))) === 'agent', 404);

        $branchName = null;
        if (!empty($agent->branch_id)) {
            $branchName = DB::table('branches')->where('id', $agent->branch_id)->value('name');
        }

        // Targets (include points_target so WOW view can show points target)
        $target = DB::table('targets')
            ->where('user_id', $agent->id)
            ->where('period', $period)
            ->select('deals_target','listings_target','value_target','points_target')
            ->first();

        $targets = [
            'deals'    => (int)($target->deals_target ?? 0),
            'listings' => (int)($target->listings_target ?? 0),
            'value'    => (float)($target->value_target ?? 0),
            'points'   => (float)($target->points_target ?? 0),
        ];

        // Deal actuals (count + sales value for value/deals targets)
        $dealActuals = DB::table('deal_user')
            ->join('deals','deals.id','=','deal_user.deal_id')
            ->where('deal_user.user_id', $agent->id)
            ->whereBetween('deals.deal_date', [$start->toDateString(), $end->toDateString()])
            ->selectRaw('COUNT(DISTINCT deal_user.deal_id) as deals_count, COALESCE(SUM(deals.property_value),0) as sales_value')
            ->first();

        $dealsDone  = (int)($dealActuals->deals_count ?? 0);
        $salesValue = (float)($dealActuals->sales_value ?? 0);

        // WOW rollup: points + momentum + activities_today
        $wow = $service->getAgentRollup((int)($agent->branch_id ?? 0), (int)$agent->id, $period);
        $pts = $wow['points'] ?? [];

        // Deals list (for detail table) — per-deal income computation for display rows
        $deals = DB::table('deal_user')
            ->join('deals','deals.id','=','deal_user.deal_id')
            ->leftJoin('users','users.id','=','deal_user.user_id')
            ->where('deal_user.user_id', $agent->id)
            ->whereBetween('deals.deal_date', [$start->toDateString(), $end->toDateString()])
            ->orderBy('deals.deal_date','desc')
            ->select(
                'deals.deal_date','deals.file_no','deals.deal_no','deals.property_address',
                'deals.property_value','deals.total_commission',
                'deals.listing_external','deals.listing_our_share_percent',
                'deals.selling_external','deals.selling_our_share_percent',
                'deal_user.side','deal_user.agent_split_percent','deal_user.agent_cut_percent',
                'users.agent_cut_percent as user_default_split_percent'
            )
            ->get()
            ->map(function ($d) {
                $sideIncomeExVat = (float) CommissionCalculator::companyIncomeExVatForSide($d, $d->side ?? null);

                $split = (float)($d->agent_split_percent ?? 0);
                if ($split < 0)   $split = 0;
                if ($split > 100) $split = 100;

                $agentIncome     = round($sideIncomeExVat * ($split / 100.0), 2);
                $companyRetained = round($sideIncomeExVat - $agentIncome, 2);

                $d->company_income_ex_vat   = round($sideIncomeExVat, 2);
                $d->agent_income_ex_vat     = $agentIncome;
                $d->company_retained_ex_vat = $companyRetained;

                return $d;
            });

        // Precompute deals table footer totals (controller — not blade)
        $dealsTotals = [
            'company_income' => round((float) $deals->sum('company_income_ex_vat'), 2),
            'agent_income'   => round((float) $deals->sum('agent_income_ex_vat'), 2),
            'retained'       => round((float) $deals->sum('company_retained_ex_vat'), 2),
        ];

        // Daily rows count for this period
        $dailyRowsCount = (int) DB::table('daily_activities')
            ->where('user_id', $agent->id)
            ->where('period', $period)
            ->count();

        // Finance Engine rollup — canonical per-stage counts + agent income
        $cv = (new FinanceReadModel())->getAgentPeriodMap((int) $agent->id, $period);

        $finance = [
            'period'     => $period,
            'run_exists' => ! empty($cv),
            'counts'     => [
                'pending'    => (int)(float)($cv['agent_period.deals.pending.count']    ?? 0),
                'granted'    => (int)(float)($cv['agent_period.deals.granted.count']    ?? 0),
                'registered' => (int)(float)($cv['agent_period.deals.registered.count'] ?? 0),
                'declined'   => (int)(float)($cv['agent_period.deals.declined.count']   ?? 0),
            ],
            'money'      => [
                'pending'    => ['agent_income_ex_vat' => (float)($cv['agent_period.money.pending.agent_income_ex_vat']    ?? 0)],
                'granted'    => ['agent_income_ex_vat' => (float)($cv['agent_period.money.granted.agent_income_ex_vat']    ?? 0)],
                'registered' => ['agent_income_ex_vat' => (float)($cv['agent_period.money.registered.agent_income_ex_vat'] ?? 0)],
                'declined'   => ['agent_income_ex_vat' => (float)($cv['agent_period.money.declined.agent_income_ex_vat']   ?? 0)],
                'total_nondeclined' => [
                    'agent_income_ex_vat'   => (float)($cv['agent_period.money.total_nondeclined.agent_income_ex_vat']   ?? 0),
                    'company_income_ex_vat' => (float)($cv['agent_period.money.total_nondeclined.company_income_ex_vat'] ?? 0),
                    'retained_ex_vat'       => (float)($cv['agent_period.money.total_nondeclined.retained_ex_vat']       ?? 0),
                ],
            ],
            'breakdowns' => [
                'pending'    => $cv['agent_period.money.pending.breakdown_json']    ?? null,
                'granted'    => $cv['agent_period.money.granted.breakdown_json']    ?? null,
                'registered' => $cv['agent_period.money.registered.breakdown_json'] ?? null,
                'declined'   => $cv['agent_period.money.declined.breakdown_json']   ?? null,
            ],
        ];

        // Precompute cross-stage totals in controller (never in blade)
        $finance['total_count_nondeclined'] = $finance['counts']['pending']
            + $finance['counts']['granted']
            + $finance['counts']['registered'];

        // Prefer stored total_nondeclined rollup value; fall back to summing stages
        $storedTotal = $finance['money']['total_nondeclined']['agent_income_ex_vat'];
        $finance['total_agent_income_nondeclined'] = $storedTotal > 0
            ? $storedTotal
            : round(
                $finance['money']['pending']['agent_income_ex_vat']
                + $finance['money']['granted']['agent_income_ex_vat']
                + $finance['money']['registered']['agent_income_ex_vat'],
                2
            );

        $actuals = [
            'deals'      => $dealsDone,
            'sales_value'=> $salesValue,
            'value'      => $salesValue,
            'daily_rows' => $dailyRowsCount,
            'points'     => (float)($pts['actual'] ?? 0),
        ];

        $progress = [
            'deals_pct'             => $targets['deals'] > 0 ? round(($dealsDone / $targets['deals']) * 100, 1) : 0,
            'value_pct'             => $targets['value'] > 0 ? round(($salesValue / $targets['value']) * 100, 1) : 0,
            'points_pct'            => (float)($pts['pct'] ?? 0),
            'points_status'         => (string)($pts['status'] ?? '—'),
            'points_per_day_needed' => (float)($pts['per_day_needed'] ?? 0),
        ];

        return view('admin.agent-performance', [
            'period'           => $period,
            'agent'            => $agent,
            'branchName'       => $branchName,
            'targets'          => $targets,
            'actuals'          => $actuals,
            'progress'         => $progress,
            'deals'            => $deals,
            'dealsTotals'      => $dealsTotals,
            'finance'          => $finance,
            'momentum_7d'      => $wow['momentum_7d'] ?? [],
            'activities_today' => $wow['activities_today'] ?? [],
        ]);
    }
}
