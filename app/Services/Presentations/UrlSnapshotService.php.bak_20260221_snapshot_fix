<?php

namespace App\Services\Presentations;

use App\Models\PresentationUrlSnapshot;
use GuzzleHttp\Client;
use GuzzleHttp\Exception\ConnectException;
use GuzzleHttp\Exception\GuzzleException;
use GuzzleHttp\Exception\RequestException;
use GuzzleHttp\RedirectMiddleware;

/**
 * Fetches a URL and stores a raw HTML snapshot with content hash.
 * No parsing is performed here — the snapshot is stored verbatim
 * so that parsers can be applied later without re-fetching.
 *
 * Captures full diagnostics: http_status, final_url, content_type,
 * content_bytes, blocked_reason, timed_out.
 */
class UrlSnapshotService
{
    public const ALLOWED_SOURCE_TYPES = [
        'p24_search',
        'p24_listing',
        'private_property',
        'private_property_search',
        'private_property_listing',
        'article',
        'other',
    ];

    private Client $http;

    public function __construct(?Client $http = null)
    {
        $this->http = $http ?? new Client([
            'timeout'         => 20,
            'connect_timeout' => 10,
            'allow_redirects' => [
                'max'             => 5,
                'strict'          => false,
                'referer'         => true,
                'track_redirects' => true,
            ],
            'http_errors'     => false,
            'headers'         => [
                'User-Agent'      => 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36',
                'Accept'          => 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8',
                'Accept-Language' => 'en-ZA,en;q=0.9,en-US;q=0.8',
                'Accept-Encoding' => 'gzip, deflate, br',
                'Cache-Control'   => 'no-cache',
                'Pragma'          => 'no-cache',
                'Sec-Fetch-Dest'  => 'document',
                'Sec-Fetch-Mode'  => 'navigate',
                'Sec-Fetch-Site'  => 'none',
                'Sec-Fetch-User'  => '?1',
                'Upgrade-Insecure-Requests' => '1',
            ],
        ]);
    }

    /**
     * Fetch the URL and store a snapshot row.
     *
     * @throws \InvalidArgumentException if source_type is invalid
     */
    public function storeSnapshot(
        int    $presentationId,
        string $url,
        string $sourceType = 'other',
    ): PresentationUrlSnapshot {
        if (!in_array($sourceType, self::ALLOWED_SOURCE_TYPES, true)) {
            throw new \InvalidArgumentException("Invalid source_type: {$sourceType}");
        }

        $html          = null;
        $httpStatus    = null;
        $hash          = null;
        $finalUrl      = null;
        $contentType   = null;
        $contentBytes  = null;
        $blockedReason = null;
        $timedOut      = false;

        try {
            $response   = $this->http->get($url);
            $httpStatus = $response->getStatusCode();
            $html       = (string) $response->getBody();
            $hash       = hash('sha256', $html);
            $contentBytes = strlen($html);

            // Extract content type
            $contentType = $response->getHeaderLine('Content-Type') ?: null;

            // Resolve final URL after redirects
            $redirectHistory = $response->getHeader(RedirectMiddleware::HISTORY_HEADER);
            $finalUrl = !empty($redirectHistory) ? end($redirectHistory) : $url;

            // Detect blocked/useless responses
            $blockedReason = $this->detectBlocked($httpStatus, $html, $contentType);

        } catch (ConnectException $e) {
            $timedOut      = true;
            $blockedReason = 'Connection timed out: ' . substr($e->getMessage(), 0, 200);
        } catch (RequestException $e) {
            if ($e->hasResponse()) {
                $response      = $e->getResponse();
                $httpStatus    = $response->getStatusCode();
                $html          = (string) $response->getBody();
                $contentBytes  = strlen($html);
                $contentType   = $response->getHeaderLine('Content-Type') ?: null;
                $blockedReason = $this->detectBlocked($httpStatus, $html, $contentType);
            } else {
                $blockedReason = 'Request failed: ' . substr($e->getMessage(), 0, 200);
            }
        } catch (GuzzleException $e) {
            $blockedReason = 'Fetch error: ' . substr($e->getMessage(), 0, 200);
        }

        return PresentationUrlSnapshot::create([
            'presentation_id' => $presentationId,
            'url'             => $url,
            'final_url'       => $finalUrl,
            'snapshot_html'   => $html,
            'source_type'     => $sourceType,
            'http_status'     => $httpStatus,
            'content_type'    => $contentType,
            'content_bytes'   => $contentBytes,
            'blocked_reason'  => $blockedReason,
            'timed_out'       => $timedOut,
            'content_hash'    => $hash,
            'fetched_at'      => now(),
        ]);
    }

    /**
     * Detect whether the response indicates a blocked or useless page.
     */
    private function detectBlocked(int $httpStatus, ?string $html, ?string $contentType): ?string
    {
        // HTTP error codes
        if ($httpStatus === 403) {
            return 'Blocked by site (HTTP 403 Forbidden)';
        }
        if ($httpStatus === 429) {
            return 'Rate limited (HTTP 429 Too Many Requests)';
        }
        if ($httpStatus >= 500) {
            return "Server error (HTTP {$httpStatus})";
        }
        if ($httpStatus === 404) {
            return 'Page not found (HTTP 404)';
        }

        // Non-HTML content type
        if ($contentType !== null && !str_contains($contentType, 'html') && !str_contains($contentType, 'text')) {
            return "Unexpected content type: {$contentType}";
        }

        if (empty($html) || strlen($html) < 200) {
            return 'Empty or near-empty response (' . strlen($html ?? '') . ' bytes)';
        }

        $htmlLower = strtolower($html);

        // Captcha / bot detection
        if (str_contains($htmlLower, 'captcha') || str_contains($htmlLower, 'recaptcha')) {
            return 'Captcha page detected';
        }

        // JS shell / SPAs that require JavaScript
        if (str_contains($htmlLower, 'enable javascript') || str_contains($htmlLower, 'please enable js')) {
            return 'JavaScript-required page (JS shell)';
        }

        // Cloudflare challenge
        if (str_contains($htmlLower, 'checking your browser') || str_contains($htmlLower, 'cf-browser-verification')) {
            return 'Cloudflare browser challenge detected';
        }

        // Access denied pages
        if (str_contains($htmlLower, 'access denied') && strlen($html) < 2000) {
            return 'Access denied page';
        }

        return null;
    }
}
