function getRefCode(type) {
  const year = new Date().getFullYear();
  const count = (SETTINGS.history.filter(h => h.type === type).length + 1).toString().padStart(4, '0');
  return `HF-${year}-${type}-${count}`;
}

function calcAll() {
  const vatRate = Math.max(0, Number(el("vatRate").value)) / 100;
  const isPocketMode = el("modePocket").checked;
  const isOverride = el("commOverrideOn").checked;
  const isVatIncl = el("vatIncl").checked;

  let sellingPrice = 0;
  let ownerPocket = 0;
  let commInc = 0;
  let commEx = 0;

  if (isOverride) {
    const amt = Math.max(0, Number(el("commOverrideAmt").value));
    const mode = el("commOverrideMode").value;
    if (mode === "inc") {
      commInc = amt;
      commEx = vatRate > 0 ? (commInc / (1 + vatRate)) : commInc;
    } else {
      commEx = amt;
      commInc = commEx * (1 + vatRate);
    }
    sellingPrice = isPocketMode ? (Number(el("ownerPocket").value) + commInc) : Number(el("price").value);
    ownerPocket = sellingPrice - commInc;
  } else {
    const commPct = Math.max(0, Number(el("commPct").value)) / 100;
    if (isPocketMode) {
      ownerPocket = Number(el("ownerPocket").value);
      const denom = isVatIncl ? (1 - commPct) : (1 - (commPct * (1 + vatRate)));
      sellingPrice = denom > 0 ? (ownerPocket / denom) : 0;
    } else {
      sellingPrice = Number(el("price").value);
    }
    const commBase = sellingPrice * commPct;
    if (isVatIncl) {
      commInc = commBase;
      commEx = commInc / (1 + vatRate);
    } else {
      commEx = commBase;
      commInc = commEx * (1 + vatRate);
    }
    ownerPocket = sellingPrice - commInc;
  }

  CALC_DATA.sellingPrice = sellingPrice;
  CALC_DATA.ownerPocket = ownerPocket;
  CALC_DATA.commInc = commInc;
  CALC_DATA.commEx = commEx;
  CALC_DATA.vat = commInc - commEx;

  el("rSellingPrice").textContent = fmtZAR(sellingPrice);
  el("rOwnerPocket").textContent = fmtZAR(ownerPocket);
  el("rTotalInc").textContent = fmtZAR(commInc);

  const propType = el("propType").value;
  const defRate = propType === "res" ? 0.075 : 0.10;
  const defCommEx = sellingPrice * defRate;
  const defCommInc = defCommEx * (1 + vatRate);
  const lostInc = Math.max(0, defCommInc - commInc);

  CALC_DATA.discountedAmt = lostInc;
  CALC_DATA.discountPct = defCommInc > 0 ? (lostInc / defCommInc) * 100 : 0;
  CALC_DATA.discountNote = `Target: ${(defRate*100).toFixed(1)}% vs Effective: ${sellingPrice > 0 ? ((commEx/sellingPrice)*100).toFixed(2) : "0"}% VAT-excl.`;

  el("rLostInc").textContent = fmtZAR(CALC_DATA.discountedAmt);
  el("rLostVsDefault").textContent = CALC_DATA.discountPct.toFixed(1) + "%";
  el("discNote").textContent = CALC_DATA.discountNote;
}

function handlePrint(html) {
  const w = window.open("", "_blank", "width=900,height=650");
  if (!w) return alert("Pop-up blocked. Please allow pop-ups for printing.");
  w.document.open();
  w.document.write(html);
  w.document.close();
  w.focus();
  setTimeout(() => {
    w.print();
    w.close();
  }, 300);
}

function addHistory(type, property, value, data) {

  const user = (window.AUTH_USER || {});
    const item = {
    id: Math.random().toString(36).substr(2, 9),
    ref: getRefCode(type),
    date: new Date().toISOString(),
    type,
    property,
    value,
    agentName: (user.name || "User"),
    data
  };
  SETTINGS.history.push(item);
  saveSettings();
}

window.loadHistoryItem = (id) => {
  const item = SETTINGS.history.find(h => h.id === id);
  if (!item) return;
  if (item.type === "CALC") {
    el("propAddress").value = item.data.propAddress || "";
    el("propType").value = item.data.propType || "res";
    el("price").value = item.data.price ?? 0;
    el("ownerPocket").value = item.data.ownerPocket ?? 0;
    el("commPct").value = item.data.commPct ?? 7.5;
    el("vatRate").value = item.data.vatRate ?? 15;
    el("vatIncl").checked = !!item.data.vatIncl;
    el("commOverrideOn").checked = !!item.data.commOverrideOn;
    el("commOverrideAmt").value = item.data.commOverrideAmt ?? 60000;
    el("commOverrideMode").value = item.data.commOverrideMode ?? "inc";
    el("modePrice").checked = item.data.mode === "price";
    el("modePocket").checked = item.data.mode === "pocket";
    el("certDate").value = item.data.certDate || "";

    el("commOverrideWrap").style.display = el("commOverrideOn").checked ? "block" : "none";
    if (el("modePocket").checked) {
      el("price").style.display = "none";
      el("ownerPocket").style.display = "block";
      el("priceLabel").textContent = "Net Pocket Target (R)";
    } else {
      el("price").style.display = "block";
      el("ownerPocket").style.display = "none";
      el("priceLabel").textContent = "Advertised Price (R)";
    }

    document.querySelector('.tab[data-target="calcSection"]').click();
    calcAll();
  } else {
    el("cmaAddress").value = item.data.cmaAddress || "";
    if (el("cmaType")) el("cmaType").value = item.data.cmaType || "House";
    el("cmaDate").value = item.data.cmaDate || "";
    el("cmaValue").value = item.data.cmaValue ?? 0;
    el("cmaBeds").value = item.data.cmaBeds || "";
    el("cmaBaths").value = item.data.cmaBaths || "";
    el("cmaParking").value = item.data.cmaParking || "";
    el("cmaNotes").value = item.data.cmaNotes || "";

    document.querySelector('.tab[data-target="certSection"]').click();
  }
};

window.deleteHistoryItem = (id) => {
  if (!confirm("Delete this history entry?")) return;
  SETTINGS.history = SETTINGS.history.filter(h => h.id !== id);
  saveSettings();
};

window.activateAgent = (id) => {
  SETTINGS.activeAgentId = id;
  saveSettings();
};

window.deleteAgent = (id) => {
  const agent = SETTINGS.agents.find(a => a.id === id);
  if (!agent) return;
  if (!confirm(`Remove agent "${agent.name}"?`)) return;
  SETTINGS.agents = SETTINGS.agents.filter(a => a.id !== id);
  if (SETTINGS.activeAgentId === id) {
    SETTINGS.activeAgentId = SETTINGS.agents[0] ? SETTINGS.agents[0].id : "";
  }
  saveSettings();
};

