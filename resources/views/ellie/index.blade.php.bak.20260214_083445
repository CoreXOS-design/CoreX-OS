{{-- ELLIE_RENAME_TOGGLE_2026 --}}
<script>
(function(){
  const btn = document.getElementById('ellieRenameBtn');
  const wrap = document.getElementById('ellieRenameWrap');
  const cancel = document.getElementById('ellieRenameCancel');
  if (!btn || !wrap) return;
  btn.addEventListener('click', function(){ wrap.classList.toggle('hidden'); });
  if (cancel) cancel.addEventListener('click', function(){ wrap.classList.add('hidden'); });
})();
</script>

{{-- ELLIE_SEND_SCRIPT_2026 --}}
<script>
document.getElementById('ellieSend')?.addEventListener('click', async function() {

    const input = document.getElementById('ellieInput');
    const message = input.value.trim();
    if (!message) return;

    input.value = '';

    const res = await fetch("{{ route('ellie.send') }}", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "X-CSRF-TOKEN": "{{ csrf_token() }}"
        },
        body: JSON.stringify({
            conversation_id: {{ $activeConversation?->id ?? 'null' }},
            message: message
        })
    });

    const data = await res.json();

    if (data.ok) {
        location.href = "{{ route('ellie.index') }}?conversation_id=" + data.conversation_id{{ request()->query('archived') == '1' ? ' + \"&archived=1\"' : '' }};
    } else {
        alert("Failed to send message");
    }
});
</script>

