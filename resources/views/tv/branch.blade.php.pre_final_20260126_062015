const tickerMsgs=@json($banner);

function rotate(el,msgs,dots,delay){
 let i=0;
 el.textContent=msgs[0];
 function drawDots(){
   dots.innerHTML='';
   msgs.forEach((_,j)=>{
     const d=document.createElement('div');
     d.className='dot'+(j===i?' active':'');
     dots.appendChild(d);
   });
 }
 drawDots();
 setInterval(()=>{
   el.classList.add('out');
   setTimeout(()=>{
     i=(i+1)%msgs.length;
     el.textContent=msgs[i];
     drawDots();
     el.classList.remove('out');
   },500);
 },delay);
}

rotate(document.getElementById('heroText'),heroMsgs,document.getElementById('dots'),12000);
rotate(document.getElementById('ticker'),tickerMsgs,{innerHTML:''},9000);
</script>

