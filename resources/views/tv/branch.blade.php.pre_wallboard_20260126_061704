const tickerMsgs = @json($banner);

function rotate(el, msgs, delay){
  let i=0;
  el.textContent = msgs[0] || "—";
  setInterval(()=>{
    el.classList.add('out');
    setTimeout(()=>{
      i=(i+1)%msgs.length;
      el.textContent = msgs[i] || "—";
      el.classList.remove('out');
    },700);
  }, delay);
}

rotate(document.getElementById('hero'), heroMsgs, 12000);
rotate(document.getElementById('ticker'), tickerMsgs, 9000);
</script>

