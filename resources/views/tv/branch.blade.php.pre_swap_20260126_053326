@php
    $r = $rollup;

    // Targets / actuals (branch)
    $targets = $r['totals']['targets'] ?? [];
    $actuals = $r['totals']['actuals'] ?? [];

    $valueTarget = (float)($targets['value'] ?? 0);
    $valueActual = (float)($actuals['value'] ?? $actuals['sales_value'] ?? 0);
    $valuePct = $valueTarget > 0 ? (($valueActual / $valueTarget) * 100) : 0;
    $valueRemaining = max($valueTarget - $valueActual, 0);

    $dealsTarget = (int)($targets['deals'] ?? 0);
    $dealsActual = (int)($actuals['deals'] ?? 0);
    $dealsPct = $dealsTarget > 0 ? (($dealsActual / $dealsTarget) * 100) : 0;
    $dealsRemaining = max($dealsTarget - $dealsActual, 0);

    // Points / pace (from BM rollup)
    $pts = $r['points'] ?? ['actual'=>0,'target'=>0,'pct'=>0,'status'=>'—','per_day_needed'=>0,'today_points'=>0,'days_left'=>0];
    $pointsActual = (float)($pts['actual'] ?? 0);
    $pointsTarget = (float)($pts['target'] ?? 0);
    $pointsPct    = (float)($pts['pct'] ?? ($pointsTarget > 0 ? (($pointsActual / $pointsTarget) * 100) : 0));
    $pointsStatus = (string)($pts['status'] ?? '—');
    $pointsPerDayNeeded = (float)($pts['per_day_needed'] ?? 0);
    $todayPoints = (float)($pts['today_points'] ?? 0);
    $daysLeft = (int)($pts['days_left'] ?? 0);

    // Today activity totals
    $today = $r['activities_today'] ?? [];
    $todayTotal = 0;
    if (is_array($today)) {
        foreach ($today as $k => $v) { $todayTotal += (int)$v; }
    }

    // Color bars
    $valueBar  = $valuePct >= 95 ? 'bg-green-600' : ($valuePct >= 75 ? 'bg-amber-500' : 'bg-red-600');
    $dealsBar  = $dealsPct >= 95 ? 'bg-green-600' : ($dealsPct >= 75 ? 'bg-amber-500' : 'bg-red-600');

    $pointsBar = 'bg-gray-900';
    if ($pointsTarget > 0) {
        if ($pointsActual >= $pointsTarget) $pointsBar = 'bg-green-600';
        elseif ($pointsStatus === 'Ahead' || $pointsStatus === 'On pace') $pointsBar = 'bg-green-600';
        elseif ($pointsPct >= 75) $pointsBar = 'bg-amber-500';
        else $pointsBar = 'bg-red-600';
    }

    // Motivational banner messages (NO agent names, NO money)
    $banner = [];
    $banner[] = "Sound the bell 🔔  Every signed deal moves the whole branch.";
    $banner[] = "This month: Deals ".number_format($dealsActual,0)." • Value R ".number_format($valueActual,0)." • Points ".number_format($pointsActual,0).".";
    $banner[] = "Still to target: ".number_format($dealsRemaining,0)." deals • R ".number_format($valueRemaining,0)." value.";
    $banner[] = "Today: ".number_format($todayTotal,0)." activity rows • ".number_format($todayPoints,0)." points so far.";
    $banner[] = ($pointsTarget > 0)
        ? ("Pace: ".$pointsStatus." • Need/day ".number_format($pointsPerDayNeeded,1)." • Days left ".number_format($daysLeft,0).".")
        : ("Set points target to unlock pace guidance.");
@endphp

