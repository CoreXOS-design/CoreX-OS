    <script>
        (function () {
            const msgs = @json($banner);
            const el = document.getElementById('banner');
            if (!msgs || msgs.length === 0 || !el) return;

            let i = 0;
            el.textContent = msgs[i] || '—';

            setInterval(() => {
                el.classList.add('out');
                setTimeout(() => {
                    i = (i + 1) % msgs.length;
                    el.textContent = msgs[i] || '—';
                    el.classList.remove('out');
                }, 500);
            }, 10000); // 10s per message (readable)
        })();
    </script>
