# CoreX off-box backup — restic environment TEMPLATE (AT-163 durability).
# Real file lives ROOT-ONLY on the server at /root/.corex-backup/restic.env (chmod 600).
# NEVER commit the real file or the password file. This template carries NO secrets.
#
# Setup on a box:
#   1) ssh-keygen -t ed25519 -f /root/.ssh/storagebox_backup -N "" -C "corex-backup"
#      → paste the .pub into the Hetzner Storage Box panel.
#   2) Add the SSH alias to /root/.ssh/config:
#        Host corex-storagebox
#            HostName <account>.your-storagebox.de
#            User <account>
#            Port 23
#            IdentityFile /root/.ssh/storagebox_backup
#            IdentitiesOnly yes
#   3) Generate the repo password (root-only, never printed):
#        umask 077; openssl rand -base64 48 > /root/.corex-backup/restic-password; chmod 600 ...
#   4) Copy this file to /root/.corex-backup/restic.env, set the repo path, chmod 600.
#   5) source it, then: restic init

export RESTIC_REPOSITORY="sftp:corex-storagebox:/home/corex-restic"
export RESTIC_PASSWORD_FILE="/root/.corex-backup/restic-password"
export RESTIC_CACHE_DIR="/root/.cache/restic"
export RESTIC_COMPRESSION="auto"
