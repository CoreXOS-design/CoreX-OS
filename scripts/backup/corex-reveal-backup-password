#!/bin/bash
#
# AT-163 — hardened reveal of the OFF-BOX backup repo (restic) password.
# Root-owned, 0700. Whitelisted for the web user (www-data) via
# /etc/sudoers.d/corex-backup-reveal (NOPASSWD, NO arguments allowed).
#
# The password stays a SINGLE root-only source file; this helper is the only
# path that reads it on behalf of the app, and only after the app has
# authorised + audit-logged the reveal. Prints the password to stdout.
#
set -euo pipefail

# Reject ALL arguments — defence in depth alongside the sudoers "" restriction.
[ "$#" -eq 0 ] || { echo "no arguments accepted" >&2; exit 64; }

PWFILE=/root/.corex-backup/restic-password
[ -r "$PWFILE" ] || { echo "backup password file unavailable" >&2; exit 1; }

cat "$PWFILE"
